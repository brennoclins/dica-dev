# ─────────────────────────────────────────────────────────────────
# Dica Dev — Environment Variables
# ─────────────────────────────────────────────────────────────────
# This file is the single source of truth for BOTH:
#   1. App runtime variables (consumed by Next.js via process.env)
#   2. Vercel build/infrastructure variables (consumed by Vercel's
#      build runner, ignored by the app if not referenced)
#
# Workflow:
#   Local dev  →  cp .env.local.example .env.local  (already done)
#   Vercel     →  Project → Settings → Environment Variables
#                → "Import .env" → upload this file
#                → enable the build-only ones for Production/Preview
#
# Rules:
#   - Real secrets go in .env.local (gitignored), NOT in this file
#   - Build-only vars do not need to be set locally; the app ignores
#     them at runtime
#   - Vercel scopes the build-only vars per environment (Production,
#     Preview, Development)
# ─────────────────────────────────────────────────────────────────


# ── App runtime: GitHub (read by src/lib/github.ts) ─────────────

# GitHub user whose repository is the source of blog posts
NEXT_PUBLIC_GITHUB_USER=brennoclins

# GitHub repository whose issues become blog posts
NEXT_PUBLIC_GITHUB_REPO=dica-dev

# (Optional, server-only) Personal Access Token to raise GitHub API
# rate limit from 60 to 5000 req/h. No scopes required for public
# repos. Create at https://github.com/settings/tokens
GITHUB_TOKEN=

# (Optional) Comma-separated extra GitHub issue labels to HIDE from
# the blog (always-on default: meta, _meta, internal, _internal, admin).
# Use this to suppress tracking/project issues (e.g. 'chore,tracking').
# Case-insensitive. Add a label to the issue on GitHub, then list it
# here and the post disappears from the home and related lists.
GITHUB_EXCLUDE_LABELS=


# ── App runtime: SEO (read by src/lib/site.ts) ──────────────────

# (Optional) Canonical site URL used by sitemap, RSS feed, JSON-LD
NEXT_PUBLIC_SITE_URL=https://dica-dev.vercel.app


# ── App runtime: Giscus comments (read by src/components/comments.tsx) ──

# (Optional) Enable Discussions on your GitHub repo first, then get
# the IDs from https://giscus.app
NEXT_PUBLIC_GISCUS_REPO_ID=
NEXT_PUBLIC_GISCUS_CATEGORY=General
NEXT_PUBLIC_GISCUS_CATEGORY_ID=


# ── App runtime: Sentry error monitoring (read by sentry.*.config.ts) ──

# (Optional) Create a Next.js project at https://sentry.io and paste
# the DSN. The app is no-op when the DSN is empty.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
# (Optional) Auth token for source-map upload. Create at
# https://sentry.io/settings/auth-tokens/ with scope 'project:releases'
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1


# ─────────────────────────────────────────────────────────────────
# Vercel build & infrastructure (NOT read by the app at runtime)
# ─────────────────────────────────────────────────────────────────
# These are consumed by the Vercel build runner. Set them in:
#   Vercel Dashboard → Project → Settings → Environment Variables
# (or import this same file via the "Import .env" button).
# No need to set them locally; Next.js ignores them at runtime.
# ─────────────────────────────────────────────────────────────────

# Enables Corepack so Vercel respects the `packageManager` field
# in package.json (pnpm@11.5.2). Without this Vercel defaults to
# pnpm 9, which fails on pnpm-workspace.yaml.
ENABLE_EXPERIMENTAL_COREPACK=1

# (Optional) Pin a specific Node.js major. Overrides the value
# configured under Project Settings → Node.js Version. The runner
# also respects the `engines.node` field in package.json
# (currently ">=22.13.0").
# VERCEL_NODE_VERSION=24

# (Optional) Region override for the build (defaults to iad1).
# VERCEL_BUILD_REGION=gru1
