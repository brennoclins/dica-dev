# GitHub user whose repository will be the source of blog posts
NEXT_PUBLIC_GITHUB_USER=brennoclins

# GitHub repository whose issues will become blog posts
NEXT_PUBLIC_GITHUB_REPO=dica-dev

# (Optional) Personal Access Token to raise GitHub API rate limit from 60 to 5000 req/h
# Create at https://github.com/settings/tokens (no scopes needed for public repos)
# GITHUB_TOKEN=

# (Optional) Canonical site URL used by sitemap, RSS feed and JSON-LD
NEXT_PUBLIC_SITE_URL=https://dica-dev.vercel.app

# (Optional) Giscus comments (https://giscus.app)
# Enable Discussions on your GitHub repo, then paste the IDs from
# the giscus.app configuration page.
NEXT_PUBLIC_GISCUS_REPO_ID=
NEXT_PUBLIC_GISCUS_CATEGORY=General
NEXT_PUBLIC_GISCUS_CATEGORY_ID=

# (Optional) Sentry error monitoring (https://sentry.io)
# Create a Next.js project at sentry.io and paste the DSN.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=
NEXT_PUBLIC_SENTRY_ENVIRONMENT=production
NEXT_PUBLIC_SENTRY_TRACES_SAMPLE_RATE=0.1
